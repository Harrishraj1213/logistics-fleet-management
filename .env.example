# Frontend
VITE_API_URL=http://localhost:3000/api
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here

# Auth Service
AUTH_PORT=3001
AUTH_DB_URL=mongodb://mongo:27017/auth_db
AUTH_JWT_SECRET=your_jwt_secret_key_change_in_production
AUTH_JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production
AUTH_JWT_EXPIRY=15m
AUTH_REFRESH_EXPIRY=7d
AUTH_EMAIL_USER=your_email@gmail.com
AUTH_EMAIL_PASSWORD=your_app_password

# Tracking Service
TRACKING_PORT=3002
TRACKING_DB_URL=mongodb://mongo:27017/tracking_db
TRACKING_REDIS_URL=redis://redis:6379

# Billing Service
BILLING_PORT=3003
BILLING_DB_URL=mongodb://mongo:27017/billing_db
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
STRIPE_SECRET_KEY=your_stripe_secret_key_optional

# Notification Service
NOTIFICATION_PORT=3004
NOTIFICATION_DB_URL=mongodb://mongo:27017/notification_db
NOTIFICATION_EMAIL_USER=your_email@gmail.com
NOTIFICATION_EMAIL_PASSWORD=your_app_password

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://ai-service:8000

# API Gateway
GATEWAY_PORT=3000
GATEWAY_ENV=development

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGO_URL=mongodb://admin:admin123@mongo:27017

# Redis
REDIS_URL=redis://redis:6379

# Node Environment
NODE_ENV=development
